# HuggingFace token — optional for VibeVoice-ASR (public model, MIT license)
# Required only if you hit rate limits or access a private model variant.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# VibeVoice-ASR model ID (single-pass STT + diarization + timestamps)
STT_MODEL=microsoft/VibeVoice-ASR

# Max new tokens to generate during transcription.
# ~8192 covers ~30 min of speech. Increase for longer recordings (model supports up to 60 min).
STT_MAX_NEW_TOKENS=8192

# vLLM server base URL — run locally with: vllm serve Qwen/Qwen3-8B
VLLM_BASE_URL=http://localhost:8000/v1

# Model name as registered in your vLLM server
VLLM_MODEL=Qwen/Qwen3-8B

# ChromaDB server — started with: docker compose up -d chroma
CHROMA_HOST=localhost
CHROMA_PORT=8009

# Embedding model from sentence-transformers (used for both chunks and queries)
EMBEDDING_MODEL=BAAI/bge-m3

# Number of chunks to retrieve per query
TOP_K_RESULTS=5

# Max tokens in LLM response
MAX_TOKENS=512

# Chunking: number of consecutive speaker turns per chunk (3 = Q + A + follow-up)
CHUNK_WINDOW_TURNS=3
# How many turns to advance between chunks (1 = max overlap, no exchange lost)
CHUNK_STRIDE_TURNS=1
