# HuggingFace token — optional for VibeVoice-ASR (public model, MIT license)
# Required only if you hit rate limits or access a private model variant.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# STT backend: "parakeet" (Whisper+pyannote), "vibevoice_vllm" (VibeVoice vLLM), or "vibevoice"
STT_BACKEND=vibevoice_vllm

# VibeVoice vLLM server (STT_BACKEND=vibevoice_vllm) — started with: docker compose up -d vibevoice
VIBEVOICE_VLLM_URL=http://localhost:8001/v1
VIBEVOICE_PORT=8001
VIBEVOICE_GPU_UTIL=0.60

# Parakeet backend model IDs (STT_BACKEND=parakeet)
# pyannote/speaker-diarization-3.1 requires licence acceptance:
#   huggingface.co/pyannote/speaker-diarization-3.1
#   huggingface.co/pyannote/segmentation-3.0
WHISPER_MODEL=openai/whisper-large-v3-turbo
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# VibeVoice-ASR model ID (single-pass STT + diarization + timestamps)
STT_MODEL=microsoft/VibeVoice-ASR

# Tokenizer backbone used by the VibeVoice processor
STT_LANGUAGE_MODEL=Qwen/Qwen2.5-7B

# Max new tokens to generate during transcription.
# ~8192 covers ~30 min of speech. Increase for longer recordings (model supports up to 60 min).
STT_MAX_NEW_TOKENS=8192

# OpenAI API — used for RAG answers, summaries, show notes
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# LLM model to use for RAG / summarization (any OpenAI chat model)
LLM_MODEL=gpt-4o-mini

# ChromaDB server — started with: docker compose up -d chroma
CHROMA_HOST=localhost
CHROMA_PORT=8010

# Embedding model from sentence-transformers (used for both chunks and queries)
EMBEDDING_MODEL=BAAI/bge-m3

# Number of chunks to retrieve per query
TOP_K_RESULTS=5

# Max tokens in LLM response
MAX_TOKENS=512

# Max characters per chunk. Turns are never split; ~1500 ≈ 2-3 min of conversation.
CHUNK_MAX_CHARS=1500

# Cross-encoder reranker: re-scores retrieved candidates before returning top-k.
# Disable to skip reranking and use raw embedding distance order.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true

# HyDE: generate a hypothetical transcript excerpt from the query, embed that
# instead of the raw query for improved recall on vague or indirect questions.
# Disable to embed the user query directly.
HYDE_ENABLED=true
