# HuggingFace token — optional (public model, MIT license)
# Required only if you hit rate limits or access a private model variant.
HF_TOKEN=

# VibeVoice-ASR vLLM server — started with: docker compose up -d
VIBEVOICE_VLLM_URL=http://localhost:8001/v1
VIBEVOICE_PORT=8001
VIBEVOICE_GPU_UTIL=0.60

# OpenAI API — used for RAG answers, summaries, show notes
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# LLM model for RAG / summarization (any OpenAI chat model)
LLM_MODEL=gpt-4o-mini

# ChromaDB server — started with: docker compose up -d
CHROMA_HOST=localhost
CHROMA_PORT=8010

# Embedding model from sentence-transformers
EMBEDDING_MODEL=BAAI/bge-m3

# Number of chunks to retrieve per query
TOP_K_RESULTS=5

# Max tokens in LLM response
MAX_TOKENS=512

# Max characters per chunk (~1500 ≈ 2-3 min of conversation)
CHUNK_MAX_CHARS=1500

# Cross-encoder reranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true

# HyDE: embed a hypothetical answer instead of the raw query for better recall
HYDE_ENABLED=true
